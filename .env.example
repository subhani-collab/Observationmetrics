# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-min-32-chars

# Comma-separated list of allowed email addresses
ALLOWED_EMAILS=admin@company.com,manager@company.com

# Initial admin account created on first startup
INITIAL_ADMIN_EMAIL=admin@company.com
INITIAL_ADMIN_NAME=Admin
INITIAL_ADMIN_PASSWORD=change-me-immediately

# ─────────────────────────────────────────────
# Google Sheets
# ─────────────────────────────────────────────
# Sheet ID from URL: /spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEET_ID=1xGPZ69xjttP8fsg7Ipna6oVwrT9Pu48kNsSlEF_BTk8

# Tab GID from URL: ?gid={GID}  (leave blank to use first sheet)
GOOGLE_SHEET_GID=856662400

# Service account credentials
# 1. Create a Google Cloud project
# 2. Enable Google Sheets API
# 3. Create a Service Account → download JSON key
# 4. Share the Google Sheet with the service account email (Viewer role)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DB_PATH=./data/dashboard.db

# ─────────────────────────────────────────────
# Sync
# ─────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=5
